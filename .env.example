# GEMINI_API_KEY: Required for Gemini AI API calls (injected automatically in AI Studio)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The hosting URL of the application
APP_URL="MY_APP_URL"

# PORT: The port the custom Express server binds to (MUST be 3000 for AI Studio proxying)
PORT=3000

# DATABASE_URL: Prisma database path connection (SQLite relative path)
DATABASE_URL="file:./dev.db"

# JWT SECRETS: Cryptographic tokens for securing Access and Refresh JWT sessions
JWT_ACCESS_SECRET="family-budget-access-key-secret-12345"
JWT_REFRESH_SECRET="family-budget-refresh-key-secret-54321"
